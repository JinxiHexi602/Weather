# QWeather API configuration for local development.
# Keep real credentials in your local environment or a private .env file only.
# The app caches each city's successful API payload for 60 seconds.

# API Host from QWeather Console, for example:
# - https://your-subdomain.qweatherapi.com
QWEATHER_API_HOST=

# JWT header "kid" value from QWeather Console.
QWEATHER_KEY_ID=

# JWT payload "sub" value, also called Project ID in QWeather Console.
QWEATHER_PROJECT_ID=

# Ed25519 private key. Do not commit the real value.
QWEATHER_PRIVATE_KEY=
